# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# Replace with your local MongoDB string or MongoDB Atlas connection string
MONGO_URI=mongodb://localhost:27017/socialmedia_db

# JWT Security
# Replace with a strong random secret key
JWT_SECRET=your_jwt_secret_key_here

# Cloudinary Configuration for Image/Video Storage
# (If left blank, application will fall back to local disk storage in the uploads/ directory)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
